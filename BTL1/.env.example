# -----------------------------
# Weights & Biases (W&B)
# -----------------------------
# Required if using WANDB_MODE=online and you are not already logged in.
WANDB_API_KEY=your_wandb_api_key

# Your W&B username or team (optional if your account default works).
WANDB_ENTITY=your_wandb_entity

# Project name used by the notebook.
WANDB_PROJECT=image-classification

# online | offline | disabled
WANDB_MODE=online

# W&B reliability controls
WANDB_INIT_TIMEOUT=180
WANDB_AUTO_SYNC_MINISTEP=1
WANDB_SYNC_EVERY_N_MINISTEPS=1
WANDB_SYNC_TIMEOUT=120
WANDB_RECOVER_ONLINE=1


# -----------------------------
# Training/runtime
# -----------------------------
# DataLoader worker count request (the notebook computes a safe effective value).
NUM_WORKERS=4

# On macOS notebooks, keep this at 0 to avoid multiprocessing spawn/pickle issues.
# Increase only if your setup is stable with notebook DataLoader workers.
NOTEBOOK_NUM_WORKERS=0

# Optional lightning logger integration (1=true, 0=false)
USE_LITLOGGER=1


# -----------------------------
# Hugging Face Hub (optional)
# -----------------------------
# Set this to avoid unauthenticated HF Hub requests (higher rate limits/faster downloads).
HF_TOKEN=your_huggingface_token

# Optional: custom local cache directory for HF assets.
# HF_HOME=.cache/huggingface

# Optional: enable hf_transfer acceleration if available in your environment.
# HF_HUB_ENABLE_HF_TRANSFER=1


# -----------------------------
# Kaggle (optional)
# -----------------------------
# Add these only if your Kaggle download flow needs env-based auth.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
